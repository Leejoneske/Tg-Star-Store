# ==========================================
# TELEGRAM BOT CONFIGURATION (CRITICAL)
# ==========================================
BOT_TOKEN=your_bot_token_here
BOT_API_URL=https://api.telegram.org
WEBHOOK_SECRET=your_webhook_secret_here
ENABLE_BOT_SIMULATOR=0

# ==========================================
# DATABASE CONFIGURATION (CRITICAL)
# ==========================================
MONGODB_URI=mongodb://localhost:27017/starstore
MONGODB_URL=mongodb://localhost:27017/starstore

# ==========================================
# PAYMENT PROVIDER (CRITICAL - FINANCIAL)
# ==========================================
PROVIDER_TOKEN=your_provider_token_here
PAYMENT_PROVIDER_TOKEN=your_provider_token_here
WALLET_ADDRESS=your_wallet_address_here

# ==========================================
# ADMIN & SECURITY (CRITICAL)
# ==========================================
ADMIN_IDS=123456789,987654321
ADMIN_TELEGRAM_IDS=123456789,987654321
SESSION_SECRET=your_session_secret_change_this_in_production
JWT_SECRET=your_jwt_secret_change_this_in_production# 🔐 CRITICAL: Admin JWT Secret (use a strong 32+ character random string, NEVER reuse BOT_TOKEN)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be set to a secure random value - application will not start without it
ADMIN_JWT_SECRET=your_strong_random_32plus_char_secret_hereAMBASSADOR_API_KEY=amb_starstore_secure_key_2024

# ==========================================
# TON BLOCKCHAIN CONFIGURATION
# Sub-Second Mainnet Ready - Updated for v2 API
# See: https://ton.org/docs/develop/infra/ton-blockchain#sub-second-architecture
# ==========================================
# Toncenter Streaming API V2 (recommended for Sub-Second mainnet)
TON_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TON_MAINNET_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
TON_API_KEY=your_toncenter_api_key

# Sub-Second Best Practices:
# - API will support Pending/Confirmed operation statuses
# - Enable transaction polling for near-instant UX (3-5 seconds confirmation)
# - Display "Pending" status immediately after transaction submission
# - Update to "Confirmed" once blockchain finalizes (masterchain)
# - WebSocket support available in Toncenter Streaming API V2

# ==========================================
# APPLICATION URLS
# ==========================================
TELEGRAM_MINI_APP_URL=https://yourdomain.com
WEBHOOK_URL=https://yourdomain.com/webhook
RAILWAY_STATIC_URL=https://yourdomain.com
RAILWAY_PUBLIC_DOMAIN=yourdomain.com

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
RESEND_API_KEY=your_resend_api_key_here
SUPPORT_EMAIL=support@starstore.app

# ==========================================
# FEATURES & LIMITS (BUSINESS RULES)
# ==========================================
MAX_DAILY_WITHDRAWAL=10000
MIN_WITHDRAWAL_AMOUNT=0.5
REFERRAL_COMMISSION_PERCENTAGE=10
FREE_STARS_MONTHLY_LIMIT=200
REPLY_MAX_RECIPIENTS=30

# ==========================================
# ENVIRONMENT & LOGGING
# ==========================================
NODE_ENV=development
LOG_LEVEL=debug
PORT=8080
ENABLE_BOT_ACTIVITY_LOGGING=1

# ==========================================
# ANALYTICS CONFIGURATION
# ==========================================
TGANALYTICS_TOKEN=your_analytics_token_here
TGANALYTICS_APP_NAME=starstore

# ==========================================
# ACTIVITY & AUDIT LOGGING
# ==========================================
ACTIVITY_RETENTION_DAYS=90
ACTIVITY_DEDUPE_MS=5000
USERACTIVITYLOG_RETENTION_DAYS=30
USERACTIVITYLOG_SAMPLE_RATE=0.5
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_PATH=./logs/audit.log

# ==========================================
# DEPLOYMENT & BUILD INFORMATION
# ==========================================
NODE_ENV=production
RAILWAY_ENVIRONMENT=production
VERCEL_ENV=production
GIT_AVAILABLE=false
RAILWAY_GIT_BRANCH=main
RAILWAY_GIT_COMMIT_SHA=abc1234567890def
RAILWAY_GIT_COMMIT_CREATED_AT=2024-01-01T00:00:00Z
RAILWAY_GIT_COMMIT_MESSAGE=Deploy to production
RAILWAY_GIT_COMMIT_AUTHOR=System

# ==========================================
# MODERATION & PRIVACY
# ==========================================
PRIVACY_USERNAMES=admin,support,moderator
