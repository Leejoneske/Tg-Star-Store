{
  "rewrites": [
    { "source": "/", "destination": "/public/index.html" },
    { "source": "/app", "destination": "/public/index.html" },

    { "source": "/sell", "destination": "/public/sell.html" },
    { "source": "/about", "destination": "/public/about.html" },
    { "source": "/history", "destination": "/public/history.html" },
    { "source": "/daily", "destination": "/public/daily.html" },
    { "source": "/referral", "destination": "/public/referral.html" },
    { "source": "/support", "destination": "/public/support.html" },
    { "source": "/notification", "destination": "/public/notification.html" },
    { "source": "/feedback", "destination": "/public/feedback.html" },
    { "source": "/ambassador", "destination": "/public/apply_ambassador.html" },
    { "source": "/amb-referral", "destination": "/public/amb_ref.html" },

    { "source": "/blog/:path*", "destination": "/public/blog/:path*" },
    { "source": "/knowledge-base/:path*", "destination": "/public/knowledge-base/:path*" },
    { "source": "/how-to-withdraw-telegram-stars/:path*", "destination": "/public/how-to-withdraw-telegram-stars/:path*" },
    { "source": "/admin/:path*", "destination": "/public/admin/:path*" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
